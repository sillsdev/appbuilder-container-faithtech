{
  "name": "sil.appbuilder.container-faithtech",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler dev",
    "dev:vite": "vite dev",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "deploy:dry-run": "vite build && wrangler deploy --dry-run --env staging",
    "types": "wrangler types",
    "types:check": "wrangler types --check",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p test/tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "playwright test",
    "check": "npm run db:validate && npm run typecheck && npm test",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "eslint --fix .",
    "prepare": "svelte-kit sync && npm run db:generate",
    "fix-sourcemaps": "node --experimental-strip-types fixSourcemaps.cts",
    "diff-db": "npm run db:validate",
    "db:format": "prisma format --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:check": "npm run db:format && npm run db:validate && npm run db:generate",
    "db:migration:initial": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script --output migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:seed:local": "wrangler d1 execute DB --local --file prisma/seed.sql",
    "db:migrate:staging": "wrangler d1 migrations apply DB --remote --env staging",
    "db:migrate:production": "wrangler d1 migrations apply DB --remote --env production"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq-otel": "^1.0.1",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@auth/core": "^0.40.0",
    "@auth/sveltekit": "^1.7.4",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.31.0",
    "@iconify/svelte": "^5.0.2",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.0.6",
    "@types/node": "^22.10.10",
    "@types/nodemailer": "^7.0.1",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@typescript-eslint/utils": "^8.44.0",
    "@zerodevx/svelte-toast": "^0.9.6",
    "commander": "^14.0.1",
    "daisyui": "^5.0.0",
    "devalue": "^5.3.2",
    "dotenv": "^17.2.3",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-svelte": "^2.46.1",
    "fuse.js": "^7.0.0",
    "globals": "^16.3.0",
    "hono": "^4.9.9",
    "nodemailer": "^7.0.6",
    "prettier": "^3.6.2",
    "prettier-eslint": "^17.0.0-alpha.1",
    "prisma": "^7.8.0",
    "sorcery": "^1.0.0",
    "svelte": "^5.19.2",
    "svelte-check": "^4.1.4",
    "svelte-flatpickr-plus": "^2.0.6",
    "sveltekit-sse": "^0.14.3",
    "sveltekit-superforms": "^2.23.1",
    "svelvet": "11.0.5",
    "tailwindcss": "^4.0.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^6.3.6",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0",
    "xstate": "^5.20.1",
    "zod": "^3.25.76"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "nodemailer": "^7.0.6"
  },
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "22.19.0"
  },
  "//auth": "@auth/core has a peerDep on v6, but it is never used",
  "//zod": "sveltekit-superforms has a peerDep on zod"
}
