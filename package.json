{
  "name": "sil.appbuilder.container-faithtech",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "db:format": "prisma format --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:check": "npm run db:format && npm run db:validate && npm run db:generate",
    "db:migration:initial": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script --output migrations/0001_initial.sql",
    "prepare": "npm run db:generate"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "22.19.0"
  }
}
